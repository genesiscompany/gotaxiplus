{
  "expo": {
    "name": "GoTaxi Brasil Plus",
    "slug": "saas-mobile",
    "version": "1.0.21",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "saas-mobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#2563EB"
    },
    "ios": {
      "supportsTablet": false,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "O GoTaxi Pro usa sua localização para navegar até o embarque e o destino.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "O GoTaxi Pro usa sua localização para navegar durante corridas."
      },
      "config": {
        "googleMapsApiKey": ""
      }
    },
    "android": {
      "package": "br.gotaxi.app",
      "versionCode": 127,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#2563EB"
      },
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED"
      ],
      "config": {
        "googleMaps": {
          "apiKey": ""
        }
      }
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "newArchEnabled": true
          },
          "ios": {
            "newArchEnabled": true
          }
        }
      ],
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "O GoTaxi Pro precisa de acesso às suas fotos para envio de documentos.",
          "cameraPermission": "O GoTaxi Pro precisa da câmera para fotografar seus documentos."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "O GoTaxi Pro usa sua localização para navegar durante corridas.",
          "locationWhenInUsePermission": "O GoTaxi Pro usa sua localização para navegar até embarque e destino."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "858d27c2-df06-4d2e-8380-0f85757e5570"
      }
    },
    "owner": "gotaxiplus"
  }
}
